---

---

<nav class="fixed top-0 z-50 w-full border-b border-white/10" style="background:rgba(0,0,0,0.85);backdrop-filter:blur(20px)">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="#" class="text-base font-bold text-white">Spendly</a>

        <div class="hidden items-center gap-8 md:flex">
            <a href="#features" class="text-sm text-white/60 transition-colors hover:text-white">Features</a>
            <a href="#screenshots" class="text-sm text-white/60 transition-colors hover:text-white">Screenshots</a>
            <a href="#deploy" class="text-sm text-white/60 transition-colors hover:text-white">Deploy</a>
            <a href="/docs/" class="text-sm text-white/60 transition-colors hover:text-white">Docs</a>
            <a
                href="https://github.com/andrejvysny/spendly"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-sm text-white/60 transition-colors hover:text-white"
            >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                GitHub
            </a>
        </div>

        <a href="#deploy" class="hidden rounded-full border border-white bg-white px-5 py-1.5 text-sm font-medium text-black transition-colors hover:bg-transparent hover:text-white md:block">
            Get Started
        </a>

        <button id="mobile-menu-btn" class="flex h-10 w-10 items-center justify-center text-white md:hidden" aria-label="Open menu">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
    </div>

    <div id="mobile-menu" class="hidden border-t border-white/10 px-6 py-4 md:hidden">
        <div class="flex flex-col gap-4">
            <a href="#features" class="text-sm text-white/60 hover:text-white">Features</a>
            <a href="#screenshots" class="text-sm text-white/60 hover:text-white">Screenshots</a>
            <a href="#deploy" class="text-sm text-white/60 hover:text-white">Deploy</a>
            <a href="/docs/" class="text-sm text-white/60 hover:text-white">Docs</a>
            <a href="https://github.com/andrejvysny/spendly" target="_blank" rel="noopener noreferrer" class="text-sm text-white/60 hover:text-white">GitHub</a>
            <a href="#deploy" class="rounded-full bg-white px-4 py-2 text-center text-sm font-medium text-black">Get Started</a>
        </div>
    </div>
</nav>

<script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => menu?.classList.add('hidden')));
</script>
