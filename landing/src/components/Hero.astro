<section class="relative pt-32 pb-24 lg:pt-44 lg:pb-32">
    <div class="relative mx-auto max-w-6xl px-6">
        <div class="max-w-3xl">
            <div class="fade-up mb-6 flex items-center gap-3">
                <span class="inline-block h-px w-8 bg-white/40"></span>
                <span class="font-mono text-xs uppercase tracking-widest text-white/40">Open source &middot; Self-hosted &middot; Free forever</span>
            </div>

            <h1 class="fade-up text-5xl font-black tracking-tighter text-white sm:text-6xl lg:text-8xl">
                Your finances.<br />
                Your server.<br />
                Your rules.
            </h1>

            <p class="fade-up mt-8 max-w-xl text-lg leading-relaxed text-white/50">
                Personal finance tracker with bank sync, smart rules, and zero subscription fees. Self-host in minutes.
            </p>

            <div class="fade-up mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
                <a href="#deploy" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold text-black transition-colors hover:bg-white/90">
                    Deploy with Docker
                    <svg class="ml-2 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                </a>
                <a href="#screenshots" class="inline-flex items-center justify-center rounded-full border border-white/20 px-8 py-3 text-sm font-medium text-white/70 transition-colors hover:border-white hover:text-white">
                    View Screenshots
                </a>
            </div>
        </div>

        <div class="fade-up mt-20 lg:mt-24">
            <div class="overflow-hidden rounded-2xl border border-white/10">
                <div class="flex items-center gap-1.5 border-b border-white/10 px-4 py-3">
                    <div class="h-2.5 w-2.5 rounded-full bg-white/20"></div>
                    <div class="h-2.5 w-2.5 rounded-full bg-white/20"></div>
                    <div class="h-2.5 w-2.5 rounded-full bg-white/20"></div>
                    <span class="ml-3 font-mono text-[10px] text-white/30">spendly / dashboard</span>
                </div>
                <img src="/screenshots/dashboard.png" alt="Spendly Dashboard" class="w-full" loading="eager" />
            </div>
        </div>
    </div>
</section>
